{
  "version": 4,
  "include": [
    "CMakePresets.json"
  ],
  "configurePresets": [
    {
      "name": "local-vs2022-x64",
      "displayName": "Local Visual Studio 2022 x64",
      "inherits": "vs2022-x64",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "E:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "environment": {
        "VCPKG_ROOT": "E:/vcpkg",
        "PATH": "E:/Qt/Tools/CMake_64/bin;$penv{PATH}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "local-vs2022-x64-debug",
      "configurePreset": "local-vs2022-x64",
      "configuration": "Debug"
    },
    {
      "name": "local-vs2022-x64-release",
      "configurePreset": "local-vs2022-x64",
      "configuration": "Release"
    }
  ]
}
